<UserControl x:Class="ETLTools.Presentation.WPF.Controls.NavigationMenuButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignWidth="38" d:DesignHeight="38">

    <Grid>
        <!-- Hamburger toggle button -->
        <Button x:Name="PART_NavButton"
                Style="{StaticResource NavButtonStyle}"
                ToolTip="Navigate to Tools"
                MouseEnter="OnNavButtonMouseEnter"
                MouseLeave="OnNavButtonMouseLeave">
            <TextBlock Text="≡"
                       FontSize="20"
                       FontFamily="Segoe UI"
                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </Button>

        <!-- Dropdown popup — DataContext is set to this UserControl in code-behind -->
        <Popup x:Name="PART_NavPopup"
               PlacementTarget="{Binding ElementName=PART_NavButton}"
               Placement="Bottom"
               VerticalOffset="4"
               HorizontalOffset="0"
               StaysOpen="True"
               AllowsTransparency="True"
               PopupAnimation="None">

            <Border x:Name="PART_PopupBorder"
                    Background="#2D2D30"
                    BorderBrush="#3F3F46"
                    BorderThickness="1"
                    CornerRadius="6"
                    MinWidth="220"
                    Padding="0,8,0,6"
                    MouseEnter="OnPopupMouseEnter"
                    MouseLeave="OnPopupMouseLeave"
                    KeyDown="OnPopupKeyDown"
                    Focusable="True">

                <Border.Effect>
                    <DropShadowEffect Color="Black"
                                      BlurRadius="14"
                                      ShadowDepth="4"
                                      Opacity="0.55"/>
                </Border.Effect>

                <StackPanel>

                    <!-- Header -->
                    <StackPanel Orientation="Horizontal" Margin="16,2,16,8">
                        <TextBlock Text="≡"
                                   Foreground="#3ECF8E"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock Text="NAVIGATION"
                                   Foreground="#6A6A6A"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Separator Background="#3F3F46"
                               Margin="0,0,0,4"
                               Height="1"
                               SnapsToDevicePixels="True"/>

                    <!-- Tool items — ItemsSource bound in code-behind via DataContext = this -->
                    <ItemsControl x:Name="PART_ItemsControl"
                                  ButtonBase.Click="OnMenuItemClicked">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button HorizontalAlignment="Stretch"
                                        Command="{Binding NavigateCommand}">

                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource NavMenuItemStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Foreground" Value="#3ECF8E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>

                                    <!-- Row: name + active checkmark -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Name}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="✓"
                                                   Foreground="#3ECF8E"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,2,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
