<UserControl x:Class="ETLTools.Presentation.WPF.Features.VersionIncrease.VersionIncreaseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ETLTools.Presentation.WPF.Features.VersionIncrease"
             xmlns:controls="clr-namespace:ETLTools.Presentation.WPF.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1200"
             Background="#1A1A1A">
    
    <UserControl.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="BackgroundDark" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="BackgroundMedium" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="BackgroundLight" Color="#282828"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#3ECF8E"/>
        <SolidColorBrush x:Key="AccentGreenHover" Color="#34C57E"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F0F0F0"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#A0A0A0"/>
        <SolidColorBrush x:Key="BorderDark" Color="#323232"/>
        
        <!-- Card Border Style -->
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BackgroundMedium}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="25"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>
        
        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentGreen}"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentGreenHover}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{StaticResource BackgroundLight}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>
    </UserControl.Resources>
    
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><!-- Header -->
            <RowDefinition Height="Auto"/><!-- Project Selection Card -->
            <RowDefinition Height="*"/>  <!-- Projects DataGrid -->
            <RowDefinition Height="Auto"/><!-- Version Update Card -->
            <RowDefinition Height="Auto"/><!-- Status Bar -->
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Version Increase Tool" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource TextPrimary}"/>
                <TextBlock Text="Automatically increment version numbers for ETL projects" 
                           FontSize="14" 
                           Foreground="{StaticResource TextSecondary}"
                           Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Navigation menu button — top-left of the header -->
            <controls:NavigationMenuButton ToolItems="{Binding NavigationMenuItems}"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Top"/>
        </Grid>
        
        <!-- Project Selection Card -->
        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock Text="Project Selection" 
                           FontSize="16" 
                           FontWeight="SemiBold" 
                           Foreground="{StaticResource TextPrimary}"
                           Margin="0,0,0,15"/>
                
                <!-- Base Directory -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBox Grid.Column="0" 
                             Text="{Binding BaseDirectory, UpdateSourceTrigger=PropertyChanged}"
                             Height="38"
                             Padding="10,0"
                             VerticalContentAlignment="Center"
                             Background="{StaticResource BackgroundLight}"
                             Foreground="{StaticResource TextPrimary}"
                             BorderBrush="{StaticResource BorderDark}"
                             BorderThickness="1"/>
                    
                    <Button Grid.Column="1" 
                            Content="Browse..." 
                            Command="{Binding BrowseDirectoryCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="100"
                            Margin="10,0,0,0"/>
                </Grid>
                
                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <Button Content="Scan Projects" 
                            Command="{Binding ScanProjectsCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                    <Button Content="Select All" 
                            Command="{Binding SelectAllCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"/>
                    <Button Content="Deselect All" 
                            Command="{Binding DeselectAllCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"/>
                </StackPanel>
                
                <!-- Status Text -->
                <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="13">
                    <Run Text="Found: "/>
                    <Run Text="{Binding FoundCount}" FontWeight="SemiBold"/>
                    <Run Text=" projects | Selected: "/>
                    <Run Text="{Binding SelectedCount}" FontWeight="SemiBold"/>
                    <Run Text=" projects"/>
                </TextBlock>
            </StackPanel>
        </Border>
        
        <!-- Projects DataGrid with Search -->
        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,20">
            <DockPanel>
                <!-- Search Section -->
                <Grid DockPanel.Dock="Top" Margin="0,0,0,15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Search Box -->
                    <Grid Grid.Row="0">
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="38"
                                 Padding="10,0,40,0"
                                 VerticalContentAlignment="Center"
                                 Background="{StaticResource BackgroundLight}"
                                 Foreground="{StaticResource TextPrimary}"
                                 BorderBrush="{StaticResource BorderDark}"
                                 BorderThickness="1">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background" Value="{StaticResource BackgroundLight}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        
                        <!-- Placeholder Text -->
                        <TextBlock Text="Search projects..."
                                   IsHitTestVisible="False"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        
                        <!-- Clear Button -->
                        <Button Content="✕"
                                Command="{Binding ClearSearchCommand}"
                                Width="30"
                                Height="30"
                                Background="Transparent"
                                Foreground="{StaticResource TextSecondary}"
                                BorderThickness="0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,5,0"
                                Cursor="Hand"
                                FontSize="16">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                    
                    <!-- Filter Status -->
                    <TextBlock Grid.Row="1"
                               Text="{Binding FilterStatusText}"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="12"
                               Margin="0,8,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FilterStatusText}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
                
                <!-- DataGrid -->
                <DataGrid ItemsSource="{Binding FilteredProjectFiles}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      SelectionMode="Extended"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      Background="{StaticResource BackgroundMedium}"
                      Foreground="{StaticResource TextPrimary}"
                      BorderThickness="0"
                      RowBackground="{StaticResource BackgroundMedium}"
                      AlternatingRowBackground="{StaticResource BackgroundLight}">
                
                <DataGrid.Columns>
                    <!-- Checkbox Column -->
                    <DataGridTemplateColumn Header="Select" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                          Checked="CheckBox_Changed"
                                          Unchecked="CheckBox_Changed"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    
                    <!-- Project Name Column -->
                    <DataGridTextColumn Header="Project Name" 
                                        Binding="{Binding FileName}" 
                                        Width="2*"/>
                    
                    <!-- Current Version Column -->
                    <DataGridTextColumn Header="Current Version" 
                                        Binding="{Binding CurrentVersion}" 
                                        Width="*"/>
                    
                    <!-- Status Column -->
                    <DataGridTextColumn Header="Status" 
                                        Binding="{Binding Status}" 
                                        Width="*"/>
                    
                    <!-- Path Column -->
                    <DataGridTextColumn Header="Path" 
                                        Binding="{Binding RelativePath}" 
                                        Width="2*"/>
                </DataGrid.Columns>
                
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{StaticResource BackgroundLight}"/>
                        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="{StaticResource BorderDark}"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource BackgroundLight}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>
            </DataGrid>
            </DockPanel>
        </Border>
        
        <!-- Version Update Card -->
        <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock Text="Version Update" 
                           FontSize="16" 
                           FontWeight="SemiBold" 
                           Foreground="{StaticResource TextPrimary}"
                           Margin="0,0,0,15"/>
                
                <!-- Progress Bar -->
                <ProgressBar Value="{Binding ProgressPercentage}" 
                             Height="8" 
                             Margin="0,0,0,15"
                             Background="{StaticResource BackgroundLight}"
                             Foreground="{StaticResource AccentGreen}"
                             Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}}"/>
                
                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal">
                    <Button Content="Increase Version"
                            Command="{Binding IncreaseVersionCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"/>

                    <Button Content="Commit &amp; Push"
                            Command="{Binding CommitAndPushCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"/>

                    <TextBlock VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="13"
                               Margin="15,0,0,0"
                               Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Run Text="Processing: "/>
                        <Run Text="{Binding ProcessedCount}"/>
                        <Run Text=" of "/>
                        <Run Text="{Binding TotalCount}"/>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Border>
        
        <!-- Status Bar -->
        <Border Grid.Row="4" 
                Background="{StaticResource BackgroundMedium}"
                BorderBrush="{StaticResource BorderDark}"
                BorderThickness="0,1,0,0"
                Padding="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" 
                       Foreground="{StaticResource TextSecondary}"
                       FontSize="12"/>
        </Border>
    </Grid>
</UserControl>
