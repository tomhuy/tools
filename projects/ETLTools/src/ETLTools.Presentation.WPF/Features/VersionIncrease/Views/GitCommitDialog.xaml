<Window x:Class="ETLTools.Presentation.WPF.Features.VersionIncrease.Views.GitCommitDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Git Commit &amp; Push"
        Height="600"
        Width="700"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A1A"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="BackgroundDark" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="BackgroundMedium" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="BackgroundLight" Color="#282828"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#3ECF8E"/>
        <SolidColorBrush x:Key="AccentGreenHover" Color="#34C57E"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F0F0F0"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#A0A0A0"/>
        <SolidColorBrush x:Key="BorderDark" Color="#323232"/>

        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentGreen}"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="30,0"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentGreenHover}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{StaticResource BackgroundLight}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <!-- TextBox Style -->
        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BackgroundLight}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <!-- ListBox Style -->
        <Style x:Key="ModernListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource BackgroundLight}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Commit Message -->
            <RowDefinition Height="Auto"/>
            <!-- Modified Files -->
            <RowDefinition Height="*"/>
            <!-- Files List -->
            <RowDefinition Height="Auto"/>
            <!-- Push Option -->
            <RowDefinition Height="Auto"/>
            <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Commit Changes"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}"/>
            <TextBlock Text="Review and commit your version changes"
                       FontSize="13"
                       Foreground="{StaticResource TextSecondary}"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Commit Message -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <TextBlock Text="Commit Message"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimary}"
                       Margin="0,0,0,8"/>
            <TextBox Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ModernTextBoxStyle}"
                     MinHeight="120"
                     MaxHeight="180"/>
        </StackPanel>

        <!-- Modified Files Header -->
        <TextBlock Grid.Row="2"
                   Text="Modified Files"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimary}"
                   Margin="0,0,0,8"/>

        <!-- Modified Files List -->
        <ListBox Grid.Row="3"
                 ItemsSource="{Binding ModifiedFiles}"
                 Style="{StaticResource ModernListBoxStyle}"
                 Margin="0,0,0,20"/>

        <!-- Push to Remote Option -->
        <StackPanel Grid.Row="4" Margin="0,0,0,25">
            <CheckBox IsChecked="{Binding PushToRemote}"
                      Foreground="{StaticResource TextPrimary}"
                      FontSize="13">
                <TextBlock>
                    <Run Text="Push to remote" FontWeight="SemiBold"/>
                    <Run Text=" (push changes to origin after commit)" Foreground="{StaticResource TextSecondary}"/>
                </TextBlock>
            </CheckBox>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Commit"
                    Command="{Binding CommitCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="0"/>
        </StackPanel>
    </Grid>
</Window>
