<UserControl x:Class="Lifes.Presentation.WPF.Features.AnnualCalendar.MonthlyCalendarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Lifes.Presentation.WPF.Features.AnnualCalendar"
             xmlns:cv="clr-namespace:Lifes.Presentation.WPF.Converters"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1200"
             d:DataContext="{d:DesignInstance Type=local:MonthlyCalendarViewModel, IsDesignTimeCreatable=False}"
             Background="#FFFFFF">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <cv:EditCellArgsConverter x:Key="EditCellArgsConverter"/>
        
        <Style x:Key="BorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style x:Key="TaskBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

        <Style x:Key="DotStyle" TargetType="Border">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <!-- Tooltip for months in popup -->
        <Style x:Key="MonthCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Margin" Value="10,5"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="HamburgerButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Border" CornerRadius="6" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <Path x:Name="Icon" Data="M3,6H21V8H3V6M3,11H21V13H3V11M3,16H21V18H3V16Z" 
                                  Fill="#4A5568" Stretch="Uniform" Width="20" Height="20"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#EDF2F7"/>
                                <Setter TargetName="Icon" Property="Fill" Value="#2D3748"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#E2E8F0"/>
                                <Setter TargetName="Icon" Property="Fill" Value="#3182CE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolMenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter x:Name="Content" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#F7FAFC"/>
                                <Setter Property="Foreground" Value="#2D3748"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter Property="Foreground" Value="#3182CE"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter TargetName="Border" Property="Background" Value="#EBF8FF"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tool Header -->
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Hamburger Menu -->
            <ToggleButton x:Name="HamburgerButton" Style="{StaticResource HamburgerButtonStyle}" Margin="0,0,10,0"/>
            
            <Popup IsOpen="{Binding IsChecked, ElementName=HamburgerButton}" 
                   PlacementTarget="{Binding ElementName=HamburgerButton}" 
                   StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Margin="0,5,0,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
                    </Border.Effect>
                    <StackPanel Margin="5" Width="200">
                        <TextBlock Text="CÔNG CỤ HỆ THỐNG" FontSize="11" FontWeight="Bold" Foreground="#A0AEC0" Margin="15,10,15,5"/>
                        <ItemsControl ItemsSource="{Binding NavigationMenuItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Name}" Command="{Binding NavigateCommand}" Style="{StaticResource ToolMenuButtonStyle}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Popup>

            <TextBlock Grid.Column="1" Text="Monthly Calendar" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center" Margin="0,0,30,0"/>

            <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <!-- Dropdown for Month Selection (Multi-select via Popup) -->
                <ToggleButton x:Name="MonthPickerButton" Content="Chọn tháng ▼" Padding="15,5" 
                              Background="White" BorderBrush="#D1D5DB" BorderThickness="1"
                              FontSize="13" FontWeight="SemiBold" Cursor="Hand">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>

                <Popup IsOpen="{Binding IsChecked, ElementName=MonthPickerButton}" 
                       PlacementTarget="{Binding ElementName=MonthPickerButton}" 
                       StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                    <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Margin="0,5,0,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
                        </Border.Effect>
                        <StackPanel Margin="10" Width="180">
                            <TextBlock Text="Chọn các tháng muốn xem" FontSize="11" FontWeight="Bold" Foreground="#6B7280" Margin="10,5,10,10"/>
                            <ItemsControl ItemsSource="{Binding AvailableMonths}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Style="{StaticResource MonthCheckBoxStyle}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Popup>

                <!-- Display Mode Splitter -->
                <Border Width="1" Height="24" Background="#E2E8F0" Margin="15,0"/>

                <!-- Tag Selection -->
                <ToggleButton x:Name="TagPickerButton" Content="Tags ▼" Padding="15,5" 
                              Background="White" BorderBrush="#D1D5DB" BorderThickness="1"
                              FontSize="13" FontWeight="SemiBold" Cursor="Hand" Margin="0,0,10,0">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>

                <Popup IsOpen="{Binding IsChecked, ElementName=TagPickerButton}" 
                       PlacementTarget="{Binding ElementName=TagPickerButton}" 
                       StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                    <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Margin="0,5,0,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
                        </Border.Effect>
                        <StackPanel Margin="10" Width="180">
                            <TextBlock Text="Chọn Tag để lọc" FontSize="11" FontWeight="Bold" Foreground="#6B7280" Margin="10,5,10,10"/>
                            <ItemsControl ItemsSource="{Binding AvailableTags}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="10,5" FontSize="13">
                                            <CheckBox.Template>
                                                <ControlTemplate TargetType="CheckBox">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Grid x:Name="MarkGrid" Width="16" Height="16" Margin="0,0,8,0">
                                                            <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="3" Background="White"/>
                                                            <Path x:Name="CheckMark" Data="M3,8L7,12L13,4" Stroke="{Binding Color}" StrokeThickness="2" Visibility="Collapsed"/>
                                                        </Grid>
                                                        <ContentPresenter VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                                            <Setter TargetName="MarkGrid" Property="ToolTip" Value="Selected"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </CheckBox.Template>
                                        </CheckBox>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            
                            <Border Height="1" Background="#F3F4F6" Margin="0,10"/>
                            
                            <CheckBox Content="Bao gồm ghi chú con" 
                                      IsChecked="{Binding IncludeChildrenOfTaggedParents}" 
                                      Margin="10,5" FontSize="12" FontWeight="SemiBold"
                                      Command="{Binding LoadDataCommand}"/>
                        </StackPanel>
                    </Border>
                </Popup>

                <ComboBox ItemsSource="{Binding AvailableDisplayModes}" 
                          SelectedItem="{Binding DisplayMode}"
                          Width="100" Height="34"
                          VerticalContentAlignment="Center"
                          Background="White" BorderBrush="#D1D5DB">
                    <ComboBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </ComboBox.Resources>
                </ComboBox>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" x:Name="MainScroll" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <Grid Grid.IsSharedSizeScope="True">
                <ItemsControl ItemsSource="{Binding DisplayMonths}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="MonthRoot" BorderBrush="#E0E0E0" BorderThickness="1,1,0,0" Background="White" Margin="0,0,0,30">
                                <StackPanel>
                                    <!-- Table Header Row 0 (Month Name) -->
                                    <Grid Height="40" Background="#F9FAFB">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition SharedSizeGroup="TitleCol"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource BorderStyle}" Background="#EDF2F7">
                                            <TextBlock Text="{Binding MonthName}" FontWeight="ExtraBold" FontSize="14" Foreground="#2D3748" VerticalAlignment="Center" Margin="15,0"/>
                                        </Border>
                                        <Border Grid.Column="1" Style="{StaticResource BorderStyle}" Background="#F9FAFB"/>
                                    </Grid>

                                    <!-- Table Header Row 1 (Day Names) -->
                                    <Grid Height="30">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition SharedSizeGroup="TitleCol"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <Border Style="{StaticResource BorderStyle}" BorderThickness="0,1,1,1" Background="#F8F9F9">
                                            <TextBlock Text="Event / Date" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#333333" FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                        
                                        <GridSplitter Grid.Column="0" Width="4" HorizontalAlignment="Right" VerticalAlignment="Stretch" Background="Transparent" Cursor="SizeWE" Panel.ZIndex="1"/>

                                        <ItemsControl Grid.Column="1" ItemsSource="{Binding DayHeaders}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource BorderStyle}" BorderThickness="0,1,1,1" Width="30" Background="#F8F9F9">
                                                        <TextBlock Text="{Binding DayName}" FontSize="10" Foreground="#7F8C8D" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>

                                    <!-- Table Header Row 2 (Day Numbers) -->
                                    <Grid Height="30">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition SharedSizeGroup="TitleCol"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <Border Style="{StaticResource BorderStyle}" Background="#F8F9F9"/>

                                        <ItemsControl Grid.Column="1" ItemsSource="{Binding DayHeaders}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="30">
                                                        <Border.Style>
                                                            <Style TargetType="Border" BasedOn="{StaticResource BorderStyle}">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                                        <Setter Property="Background" Value="#FF4D4D"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding DayNumber, StringFormat='\{0:D2\}'}" FontSize="11" FontWeight="Bold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#2C3E50"/>
                                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                                            <Setter Property="Foreground" Value="White"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>

                                    <!-- Table Body -->
                                    <ItemsControl ItemsSource="{Binding EventRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Height="30">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition SharedSizeGroup="TitleCol"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Title column -->
                                                    <Border Style="{StaticResource BorderStyle}">
                                                        <Button Style="{StaticResource GhostButtonStyle}"
                                                                Command="{Binding DataContext.OpenEditPopupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                            <Button.CommandParameter>
                                                                <MultiBinding Converter="{StaticResource EditCellArgsConverter}">
                                                                    <Binding /> <!-- Direct reference to MonthlyEventRowViewModel -->
                                                                    <Binding Path="DataContext.MonthValue" ElementName="MonthRoot" />
                                                                    <Binding>
                                                                        <Binding.Source>
                                                                            <sys:Int32>-1</sys:Int32>
                                                                        </Binding.Source>
                                                                    </Binding>
                                                                    <Binding Path="MementoId" />
                                                                </MultiBinding>
                                                            </Button.CommandParameter>
                                                            <StackPanel Orientation="Horizontal" Margin="10,0">
                                                                <Rectangle Width="4" Height="16" Fill="{Binding BgColor}" RadiusX="2" RadiusY="2" Margin="0,0,8,0"/>
                                                                <TextBlock Text="{Binding Title}" 
                                                                           VerticalAlignment="Center" 
                                                                           TextTrimming="CharacterEllipsis"
                                                                           ToolTip="{Binding Title}"
                                                                           Foreground="#2C3E50" 
                                                                           FontSize="11"
                                                                           FontWeight="SemiBold"/>
                                                            </StackPanel>
                                                        </Button>
                                                    </Border>

                                                    <!-- Days columns background grid -->
                                                    <Grid Grid.Column="1">
                                                        <!-- Background vertical lines -->
                                                        <ItemsControl ItemsSource="{Binding DataContext.DayHeaders, ElementName=MonthRoot}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal" IsItemsHost="True"/>
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border x:Name="Cell" Width="30" Style="{StaticResource BorderStyle}" Background="Transparent">
                                                                        <Grid>
                                                                            <Button Style="{StaticResource GhostButtonStyle}"
                                                                                    Command="{Binding DataContext.OpenEditPopupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                                                <Button.CommandParameter>
                                                                                    <MultiBinding Converter="{StaticResource EditCellArgsConverter}">
                                                                                        <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=Grid, AncestorLevel=2}" />
                                                                                        <Binding Path="DataContext.MonthValue" ElementName="MonthRoot" />
                                                                                        <Binding Path="DayNumber" />
                                                                                    </MultiBinding>
                                                                                </Button.CommandParameter>
                                                                            </Button>
                                                                            
                                                                            <Button x:Name="ColorPickerButton" 
                                                                                    Visibility="Collapsed"
                                                                                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                                                    Margin="0,0,2,2" Cursor="Hand"
                                                                                    Command="{Binding DataContext.OpenColorPickerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                                                <Button.Template>
                                                                                    <ControlTemplate TargetType="Button">
                                                                                        <Path Data="M7,10L12,15L17,10H7Z" Fill="#A0AEC0" Width="12" Height="12" Stretch="Uniform"/>
                                                                                    </ControlTemplate>
                                                                                </Button.Template>
                                                                                <Button.CommandParameter>
                                                                                    <MultiBinding Converter="{StaticResource EditCellArgsConverter}">
                                                                                        <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=Grid, AncestorLevel=2}" />
                                                                                        <Binding Path="DataContext.MonthValue" ElementName="MonthRoot" />
                                                                                        <Binding Path="DayNumber" />
                                                                                    </MultiBinding>
                                                                                </Button.CommandParameter>
                                                                            </Button>
                                                                        </Grid>
                                                                    </Border>
                                                                    <DataTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Cell" Property="Background" Value="#F7FAFC"/>
                                                                            <Setter TargetName="ColorPickerButton" Property="Visibility" Value="Visible"/>
                                                                        </Trigger>
                                                                    </DataTemplate.Triggers>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>

                                                        <!-- Gantt Bar Overlay -->
                                                        <Grid VerticalAlignment="Center" Height="22" Margin="0">
                                                            <ItemsControl ItemsSource="{Binding Bars}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="30"/><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/>
                                                                            </Grid.ColumnDefinitions>
                                                                        </Grid>
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemContainerStyle>
                                                                    <Style TargetType="ContentPresenter">
                                                                        <Setter Property="Grid.Column" Value="{Binding StartColumn}"/>
                                                                        <Setter Property="Grid.ColumnSpan" Value="{Binding Duration}"/>
                                                                    </Style>
                                                                </ItemsControl.ItemContainerStyle>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border x:Name="BarBorder" 
                                                                                Style="{StaticResource TaskBorderStyle}"
                                                                                Margin="1,0"
                                                                                ToolTip="{Binding Title}">
                                                                            <Grid>
                                                                                <Button Style="{StaticResource GhostButtonStyle}"
                                                                                        Command="{Binding DataContext.OpenEditPopupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                                                    <Button.CommandParameter>
                                                                                        <MultiBinding Converter="{StaticResource EditCellArgsConverter}">
                                                                                            <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=Grid, AncestorLevel=2}" />
                                                                                            <Binding Path="DataContext.MonthValue" ElementName="MonthRoot" />
                                                                                            <Binding Path="StartColumn" />
                                                                                            <Binding Path="MementoId" />
                                                                                        </MultiBinding>
                                                                                    </Button.CommandParameter>
                                                                                </Button>

                                                                                <Button x:Name="BarColorPickerButton" 
                                                                                        Visibility="Collapsed"
                                                                                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                                                        Margin="0,0,2,2" Cursor="Hand"
                                                                                        Command="{Binding DataContext.OpenColorPickerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                                                    <Button.Template>
                                                                                        <ControlTemplate TargetType="Button">
                                                                                            <Path Data="M7,10L12,15L17,10H7Z" Fill="#FFFFFF" Width="10" Height="10" Stretch="Uniform" Opacity="0.8"/>
                                                                                        </ControlTemplate>
                                                                                    </Button.Template>
                                                                                    <Button.CommandParameter>
                                                                                        <MultiBinding Converter="{StaticResource EditCellArgsConverter}">
                                                                                            <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=Grid, AncestorLevel=2}" />
                                                                                            <Binding Path="DataContext.MonthValue" ElementName="MonthRoot" />
                                                                                            <Binding Path="StartColumn" />
                                                                                            <Binding Path="MementoId" />
                                                                                        </MultiBinding>
                                                                                    </Button.CommandParameter>
                                                                                </Button>
                                                                                <!-- Gantt Mode Content -->
                                                                                <TextBlock x:Name="GanttText" 
                                                                                           Text="{Binding Title}" 
                                                                                           Foreground="{Binding FgColor}" 
                                                                                           FontSize="9" 
                                                                                           FontWeight="SemiBold" 
                                                                                           VerticalAlignment="Center" 
                                                                                           HorizontalAlignment="Center" 
                                                                                           TextTrimming="CharacterEllipsis"
                                                                                           Margin="5,0"/>

                                                                                <!-- Dot Mode Content -->
                                                                                <ItemsControl x:Name="DotsRepeater" ItemsSource="{Binding DayIndices}" Visibility="Collapsed">
                                                                                    <ItemsControl.ItemsPanel>
                                                                                        <ItemsPanelTemplate>
                                                                                            <StackPanel Orientation="Horizontal"/>
                                                                                        </ItemsPanelTemplate>
                                                                                    </ItemsControl.ItemsPanel>
                                                                                    <ItemsControl.ItemTemplate>
                                                                                        <DataTemplate>
                                                                                            <Border Width="30" Style="{StaticResource DotStyle}">
                                                                                                <Ellipse Fill="{Binding DataContext.BgColor, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                                                                         Width="10" Height="10"/>
                                                                                            </Border>
                                                                                        </DataTemplate>
                                                                                    </ItemsControl.ItemTemplate>
                                                                                </ItemsControl>
                                                                            </Grid>
                                                                        </Border>

                                                                        <DataTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="BarColorPickerButton" Property="Visibility" Value="Visible"/>
                                                                            </Trigger>
                                                                            <DataTrigger Binding="{Binding DataContext.DisplayMode, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="Gantt">
                                                                                <Setter TargetName="BarBorder" Property="Background" Value="{Binding BgColor}"/>
                                                                                <Setter TargetName="GanttText" Property="Visibility" Value="Visible"/>
                                                                                <Setter TargetName="DotsRepeater" Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding DataContext.DisplayMode, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="Dot">
                                                                                <Setter TargetName="BarBorder" Property="Background" Value="#10000000"/> <!-- Faint background -->
                                                                                <Setter TargetName="BarBorder" Property="BorderBrush" Value="{Binding BgColor}"/>
                                                                                <Setter TargetName="BarBorder" Property="BorderThickness" Value="1"/>
                                                                                <Setter TargetName="GanttText" Property="Visibility" Value="Collapsed"/>
                                                                                <Setter TargetName="DotsRepeater" Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding DataContext.DisplayMode, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="PureDot">
                                                                                <Setter TargetName="BarBorder" Property="Background" Value="Transparent"/>
                                                                                <Setter TargetName="BarBorder" Property="BorderThickness" Value="0"/>
                                                                                <Setter TargetName="GanttText" Property="Visibility" Value="Collapsed"/>
                                                                                <Setter TargetName="DotsRepeater" Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </DataTemplate.Triggers>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </Grid>
                                                    </Grid>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>

        <!-- Edit Popup -->
        <Popup IsOpen="{Binding IsEditPopupOpen}" StaysOpen="False" Placement="MousePoint" AllowsTransparency="True" PopupAnimation="Fade">
            <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Width="300">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.15"/>
                </Border.Effect>
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,-10,-10">
                        <Button Command="{Binding DeleteMementoCommand}" Cursor="Hand" Background="Transparent" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19V4M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" Fill="#FC8181" Width="18" Height="18" Stretch="Uniform" Margin="10"/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <TextBlock Text="Cập nhật thông tin" FontSize="14" FontWeight="Bold" Foreground="#2D3748" Margin="0,0,0,15"/>
                    
                    <TextBox Grid.Row="1" Text="{Binding EditingTitle, UpdateSourceTrigger=PropertyChanged}" 
                             FontSize="13" Padding="12,10" Margin="0,0,0,15"
                             BorderBrush="#E2E8F0" BorderThickness="1">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <!-- Tag Selection Section -->
                    <StackPanel Grid.Row="1" Visibility="{Binding IsShowEditingTag, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,15">
                        <TextBlock Text="PHÂN LOẠI (TAGS)" FontSize="11" FontWeight="Bold" Foreground="#A0AEC0" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding EditingMementoTags}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected}" Margin="0,0,10,6">
                                        <CheckBox.Template>
                                            <ControlTemplate TargetType="CheckBox">
                                                <Border x:Name="TagBorder" Padding="8,4" CornerRadius="4" BorderThickness="1" BorderBrush="#E2E8F0" Background="White">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Ellipse Fill="{Binding Color}" Width="8" Height="8" Margin="0,0,6,0"/>
                                                        <ContentPresenter VerticalAlignment="Center">
                                                            <ContentPresenter.Content>
                                                                <TextBlock Text="{Binding Name}" FontSize="11" Foreground="#4A5568"/>
                                                            </ContentPresenter.Content>
                                                        </ContentPresenter>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="TagBorder" Property="Background" Value="#F0F9FF"/>
                                                        <Setter TargetName="TagBorder" Property="BorderBrush" Value="#3182CE"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="TagBorder" Property="BorderBrush" Value="#CBD5E0"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </CheckBox.Template>
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Button Grid.Row="2" Content="Lưu thông tin" Command="{Binding SaveEditCommand}" 
                            Background="#3182CE" Foreground="White" FontWeight="Bold" FontSize="13" Height="40">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>
        </Popup>

        <!-- Color Picker Popup -->
        <Popup IsOpen="{Binding IsColorPopupOpen}" StaysOpen="False" Placement="MousePoint" AllowsTransparency="True" PopupAnimation="Fade">
            <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="15">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.15"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="CHỌN MÀU SẮC" FontSize="11" FontWeight="Bold" Foreground="#A0AEC0" Margin="5,0,0,12"/>
                    <ItemsControl ItemsSource="{Binding ColorPalette}" Width="180">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="6"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.SetColorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                        CommandParameter="{Binding}"
                                        Margin="4" Cursor="Hand" Width="24" Height="24">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid>
                                                <Ellipse Fill="{Binding}" Width="20" Height="20"/>
                                                <Ellipse x:Name="Highlight" Stroke="#3182CE" StrokeThickness="2" Width="24" Height="24" Visibility="Collapsed"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Highlight" Property="Visibility" Value="Visible"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
