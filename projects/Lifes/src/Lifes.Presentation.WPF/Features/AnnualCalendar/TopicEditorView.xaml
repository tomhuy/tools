<UserControl x:Class="Lifes.Presentation.WPF.Features.AnnualCalendar.TopicEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Lifes.Presentation.WPF.Features.AnnualCalendar"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="400">
    <Border Background="White" CornerRadius="12" Padding="24" BorderBrush="#E2E8F0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.1"/>
        </Border.Effect>
        <StackPanel>
            <TextBlock Text="{Binding HeaderTitle}" Foreground="#2D3748" FontSize="20" FontWeight="Bold" Margin="0,0,0,24"/>

            <!-- Tiêu đề & Thứ tự -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Tiêu đề" Foreground="#718096" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" 
                             Background="White" Foreground="#2D3748" BorderBrush="#E2E8F0" 
                             Padding="10,8" Height="38" VerticalContentAlignment="Center">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </TextBox.Resources>
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SaveCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Thứ tự" Foreground="#718096" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding Order, UpdateSourceTrigger=PropertyChanged}" 
                             Background="White" Foreground="#2D3748" BorderBrush="#E2E8F0" 
                             Padding="10,8" Height="38" VerticalContentAlignment="Center">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </StackPanel>
            </Grid>

            <!-- Ngày tháng -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Ngày bắt đầu" Foreground="#718096" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <DatePicker SelectedDate="{Binding StartDate}" Background="White" BorderBrush="#E2E8F0"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Ngày kết thúc" Foreground="#718096" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <DatePicker SelectedDate="{Binding EndDate}" Background="White" BorderBrush="#E2E8F0"/>
                </StackPanel>
            </Grid>

            <!-- Chọn Tags -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Gán Tags" Foreground="#718096" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <ItemsControl ItemsSource="{Binding AvailableTags}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected}" Margin="0,0,8,6">
                                <CheckBox.Template>
                                    <ControlTemplate TargetType="CheckBox">
                                        <Border x:Name="TagBorder" Padding="8,4" CornerRadius="4" 
                                                Background="#F7FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Cursor="Hand">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="8" Height="8" Fill="{Binding Color}" Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding Name}" Foreground="#4A5568" FontSize="11"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="TagBorder" Property="Background" Value="#EBF8FF"/>
                                                <Setter TargetName="TagBorder" Property="BorderBrush" Value="#3182CE"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="TagBorder" Property="BorderBrush" Value="#3182CE"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </CheckBox.Template>
                            </CheckBox>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Màu sắc -->
            <StackPanel Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Màu đại diện Topic" Foreground="#718096" FontSize="12" FontWeight="SemiBold"/>
                    <Border Width="14" Height="14" Margin="10,0,0,0" CornerRadius="7" 
                            Background="{Binding SelectedColor}" BorderBrush="#E2E8F0" BorderThickness="1"/>
                </StackPanel>
                
                <ItemsControl ItemsSource="{Binding ColorPalette}" HorizontalAlignment="Left">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="8"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.SetColorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Width="36" Height="36" Margin="2" Padding="0" BorderThickness="0" Background="Transparent" Cursor="Hand">
                                <Grid>
                                    <!-- Hover Ring -->
                                    <Ellipse x:Name="HoverRing" Width="32" Height="32" Stroke="Transparent" StrokeThickness="2"/>
                                    
                                    <!-- Actual Color Circle -->
                                    <Ellipse Width="24" Height="24" Fill="{Binding}" Stroke="#E2E8F0" StrokeThickness="1"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Nút bấm -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1" Content="Hủy bỏ" Command="{Binding CancelCommand}"
                        Width="100" Height="38" Margin="0,0,12,0"
                        Background="Transparent" Foreground="#718096" BorderBrush="#E2E8F0" BorderThickness="1" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
                
                <Button Grid.Column="2" Content="Lưu thông tin" Command="{Binding SaveCommand}"
                        Width="120" Height="38" 
                        Background="#3ECF8E" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
