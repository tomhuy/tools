<UserControl x:Class="Lifes.Presentation.WPF.Features.DocumentManagement.DocumentManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Lifes.Presentation.WPF.Features.DocumentManagement"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1200"
             d:DataContext="{d:DesignInstance Type=local:DocumentManagementViewModel, IsDesignTimeCreatable=False}"
             Background="#FFFFFF">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <!-- Style for table borders -->
        <Style x:Key="BorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>



        <!-- DataTemplate for Day Cell -->
        <DataTemplate x:Key="DayCellTemplate">
            <Border Width="25" Style="{StaticResource BorderStyle}">
                <!-- Display X if active -->
                <TextBlock Text="X" 
                           Foreground="#666666" 
                           FontWeight="Normal"
                           FontSize="13"
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           Visibility="{Binding IsActive, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Border>
        </DataTemplate>

    </UserControl.Resources>

        <ScrollViewer x:Name="MainScroll" SizeChanged="MainScroll_SizeChanged" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Margin="20">
            <Border BorderBrush="#E0E0E0" BorderThickness="1,1,0,0" Background="White" Grid.IsSharedSizeScope="True">
                <StackPanel>
                    
                    <!-- Table Header Row 1 (Day Names) -->
                    <Grid Height="25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="TitleColDef" Width="400" SharedSizeGroup="TitleCol"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Top left cell (Month/Year) -->
                        <Border Style="{StaticResource BorderStyle}" BorderThickness="0,1,1,1">
                            <TextBlock Text="{Binding MonthName}" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" Foreground="#333333" FontSize="11" FontWeight="Normal"/>
                        </Border>
                        
                        <GridSplitter DragStarted="GridSplitter_DragStarted" Grid.Column="0" Width="3" HorizontalAlignment="Right" VerticalAlignment="Stretch" Background="Transparent" Cursor="SizeWE" Panel.ZIndex="1"/>

                        <ItemsControl Grid.Column="1" ItemsSource="{Binding DayHeaders}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource BorderStyle}" BorderThickness="0,1,1,1" Width="25" Background="Transparent">
                                        <TextBlock Text="{Binding DayName}" FontSize="11" Foreground="#666666" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <!-- Table Header Row 2 (Day Numbers) -->
                    <Grid Height="25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition SharedSizeGroup="TitleCol"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Style="{StaticResource BorderStyle}">
                            <TextBlock Text="task\ngày" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" Foreground="#666666" FontSize="11" FontWeight="Normal"/>
                        </Border>
                        
                        <GridSplitter DragStarted="GridSplitter_DragStarted" Grid.Column="0" Width="3" HorizontalAlignment="Right" VerticalAlignment="Stretch" Background="Transparent" Cursor="SizeWE" Panel.ZIndex="1"/>

                        <ItemsControl Grid.Column="1" ItemsSource="{Binding DayHeaders}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="25">
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource BorderStyle}">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                        <Setter Property="Background" Value="#FF4D4D"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding DayNumber}" FontSize="11">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#666666"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <!-- Table Body -->
                    <ItemsControl ItemsSource="{Binding DocumentRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="25">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition SharedSizeGroup="TitleCol"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Title column -->
                                    <Border Style="{StaticResource BorderStyle}">
                                        <TextBlock Text="{Binding Title}" 
                                                   VerticalAlignment="Center" 
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Title}"
                                                   Foreground="#333333" 
                                                   FontSize="11">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Margin" Value="10,0,10,0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSubtask}" Value="True">
                                                            <Setter Property="Margin" Value="25,0,10,0"/>
                                                            <Setter Property="Foreground" Value="#666666"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <!-- Days columns -->
                                    <ItemsControl Grid.Column="1" ItemsSource="{Binding Cells}" ItemTemplate="{StaticResource DayCellTemplate}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </ScrollViewer>
</UserControl>
