<UserControl x:Class="Lifes.Presentation.WPF.Features.SprintBoard.SprintBoardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="#FAFBFC">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Main Header Bar -->
        <Grid Grid.Row="0" Margin="30,20,30,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Sprint Board" FontSize="24" FontWeight="Bold" Foreground="#2D3748" VerticalAlignment="Center"/>
            
            <Border Grid.Column="1" Background="#EBF4FF" CornerRadius="12" Padding="10,4" Margin="15,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="Sprint 12" Foreground="#3182CE" FontWeight="SemiBold" FontSize="12"/>
            </Border>

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <CheckBox Content="Hiện task done" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="#4A5568" FontWeight="Medium" IsChecked="True"/>
                <Button Content="+ Feature" Background="White" Foreground="#4A5568" FontWeight="SemiBold" Padding="15,8" BorderBrush="#E2E8F0" BorderThickness="1">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Assignee Pills Row -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding AssigneePills}" Margin="30,0,30,20">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="{Binding ThemeColor}" BorderThickness="1" CornerRadius="18" Padding="6,4,15,4" Margin="0,0,10,0" Background="{Binding BgColor}">
                        <StackPanel Orientation="Horizontal">
                            <!-- Initials Circle -->
                            <Border Width="26" Height="26" CornerRadius="13" Background="White" BorderBrush="{Binding ThemeColor}" BorderThickness="0">
                                <TextBlock Text="{Binding Initials}" Foreground="{Binding ThemeColor}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="11"/>
                            </Border>

                            <!-- Name and Summary -->
                            <TextBlock Text="{Binding TotalCount}" Foreground="{Binding ThemeColor}" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" Margin="8,0,5,0"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="{Binding ThemeColor}" FontSize="12" Margin="0,-1,0,1"/>
                                <TextBlock Text="{Binding SummaryText}" Foreground="{Binding ThemeColor}" Opacity="0.75" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Main Board / Grid Matrix -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <StackPanel Margin="30,0,30,30" MinWidth="1100">
                
                <!-- Table Headers -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="FEATURE" Foreground="#A0AEC0" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,15"/>

                    <ItemsControl Grid.Column="1" ItemsSource="{Binding BoardColumns}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E2E8F0" BorderThickness="0,0,1,0" Padding="0,10">
                                    <Grid>
                                        <!-- Assignee Column Header -->
                                        <StackPanel HorizontalAlignment="Center" Visibility="{Binding IsAssignee, Converter={StaticResource BoolToVis}}">
                                            <Border Width="32" Height="32" CornerRadius="16" Background="{Binding Assignee.BgColor}">
                                                <TextBlock Text="{Binding Assignee.Initials}" Foreground="{Binding Assignee.ThemeColor}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="11"/>
                                            </Border>
                                            <TextBlock Text="{Binding Assignee.Name}" FontWeight="SemiBold" Foreground="#2D3748" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Làm Trước Header (Not Assignee) -->
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding IsNotAssignee, Converter={StaticResource BoolToVis}}">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Path Data="M 0,5 L 10,5 M 5,0 L 5,10" Stroke="#A0AEC0" StrokeThickness="1.5" Width="10" Height="10" Margin="0,0,5,0"/>
                                                <TextBlock Text="{Binding Title}" Foreground="#A0AEC0" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>

                <Border Height="1" Background="#E2E8F0" Margin="0,0,0,10"/>

                <!-- Matrix Feature Rows -->
                <ItemsControl ItemsSource="{Binding FeatureRows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left Feature Summary column -->
                                <Border Grid.Column="0" BorderBrush="#E2E8F0" BorderThickness="1,0,1,0" Padding="15" Background="White">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" Opacity="0.02" ShadowDepth="1" BlurRadius="4"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Border Width="4" HorizontalAlignment="Left" Background="{Binding Feature.IndicatorColor}" CornerRadius="2" Margin="-15,-15,0,-15"/>
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding Feature.Title}" FontWeight="SemiBold" Foreground="#2D3748" FontSize="13" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>
                                            <TextBlock Text="{Binding Feature.SummaryText}" Foreground="#A0AEC0" FontSize="12" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Right Task rows -->
                                <ItemsControl Grid.Column="1" ItemsSource="{Binding TaskRows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                                                <ItemsControl ItemsSource="{Binding Cells}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <UniformGrid Rows="1"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border BorderBrush="#E2E8F0" BorderThickness="0,0,1,0" Padding="10" MinHeight="45"
                                                                    Background="Transparent"
                                                                    AllowDrop="True"
                                                                    Drop="TaskCell_Drop"
                                                                    DragOver="TaskCell_DragOver">
                                                                <!-- Task Cell display if present -->
                                                                <Border Background="{Binding Task.StatusColor}" 
                                                                        BorderBrush="{Binding Task.BorderColor}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="6" 
                                                                        Padding="8,5" 
                                                                        HorizontalAlignment="Left"
                                                                        MouseMove="TaskCard_MouseMove"
                                                                        MouseLeftButtonDown="TaskCard_MouseLeftButtonDown"
                                                                        Visibility="{Binding HasTask, Converter={StaticResource BoolToVis}}">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        
                                                                        <TextBlock Grid.Column="0" TextWrapping="Wrap" VerticalAlignment="Center" Foreground="{Binding Task.TextColor}">
                                                                            <Run Text="{Binding Task.Id}" FontWeight="Bold"/>
                                                                            <Run Text=" "/>
                                                                            <Run Text="{Binding Task.Title}" FontWeight="SemiBold" FontSize="12"/>
                                                                        </TextBlock>
                                                                        
                                                                        <!-- Green Check icon for DONE tasks -->
                                                                        <Border Grid.Column="1" Width="16" Height="16" CornerRadius="8" Background="#27AE60" Margin="10,0,0,0" Visibility="{Binding Task.IsDone, Converter={StaticResource BoolToVis}}" VerticalAlignment="Center">
                                                                            <Path Data="M 4,8 L 7,11 L 11,4" Stroke="White" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </Grid>
                                                                </Border>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
